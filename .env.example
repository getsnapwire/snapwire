# ===================================================
# Agentic Firewall - Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values
# Only DATABASE_URL is required for basic operation
# ===================================================

# --- Database ---
# PostgreSQL connection string (required for production)
# Leave empty to use local SQLite (good for testing)
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentic_firewall

# --- Session ---
# Secret key for session encryption (auto-generated if not set)
# SESSION_SECRET=your-random-secret-here

# --- Server ---
# Port to run the server on (default: 5000)
# PORT=5000

# --- AI Provider ---
# Choose your AI provider: "anthropic" or "openai" (auto-detected from keys)
# LLM_PROVIDER=anthropic

# Anthropic (Claude) - set one of these:
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT) - set this for OpenAI:
# OPENAI_API_KEY=sk-...

# Custom model override (optional):
# LLM_MODEL=claude-sonnet-4-5

# --- Email Notifications ---
# SMTP settings for email alerts (optional - logs to console if not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TLS=true

# --- Template URL ---
# Where to direct users who want to fork/deploy their own instance
# TEMPLATE_URL=https://github.com/agenticfirewall/agentic-firewall

# --- App Domain ---
# Public domain for webhook callbacks and links (auto-detected if not set)
# APP_DOMAIN=your-server.com

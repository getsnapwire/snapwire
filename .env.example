# ===================================================
# Snapwire — Environment Configuration
# ===================================================
# Copy this file to .env and fill in your values.
# No variables are strictly required — Snapwire will
# use sensible defaults (SQLite, auto-generated session
# secret, console logging) if nothing is set.
# ===================================================

# --- Database ---
# PostgreSQL connection string (recommended for production)
# Falls back to local SQLite if not set (fine for testing)
# DATABASE_URL=postgresql://user:pass@localhost:5432/snapwire

# --- Session ---
# Secret key for session encryption
# Auto-generated if not set (set this in production)
# SESSION_SECRET=your-random-secret-here

# --- Server ---
# Port to run the server on (default: 5000)
# PORT=5000

# --- AI Provider ---
# Required for AI-powered features (rule evaluation, goal drift alerts)
# Deterministic features (loop detection, schema guard, burn meter)
# work without an AI provider.
#
# Provider is auto-detected from whichever key you set.
# To force one: LLM_PROVIDER=anthropic or LLM_PROVIDER=openai
#
# Anthropic (Claude):
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI (GPT):
# OPENAI_API_KEY=sk-...
#
# Custom model override (optional):
# LLM_MODEL=claude-sonnet-4-5

# --- Email Notifications (optional) ---
# SMTP settings for email alerts
# Falls back to console logging if not set
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TLS=true

# --- Public URL (optional) ---
# Public domain for webhook callbacks and links
# Auto-detected on Replit; set manually for other platforms
# APP_DOMAIN=your-server.com

# --- Telemetry (optional) ---
# Opt-in anonymous telemetry (daily ping with aggregate stats)
# Set to "false" or remove to disable
# SNAPWIRE_TELEMETRY=false

# --- Privacy ---
# Set to disable all optional tracking
# DO_NOT_TRACK=1

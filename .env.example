# Snapwire — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ─── Required ───────────────────────────────────────────────────────────────

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-use-a-random-32-char-string

# Database URL — PostgreSQL recommended for production, SQLite for local dev
# PostgreSQL: postgresql://user:password@localhost:5432/snapwire
# SQLite:     sqlite:///snapwire.db
DATABASE_URL=postgresql://user:password@localhost:5432/snapwire

# ─── Admin Access ────────────────────────────────────────────────────────────

# Comma-separated list of super admin email addresses
ADMIN_EMAIL=hello@yourcompany.com

# ─── LLM Providers (at least one required for AI features) ───────────────────

# Anthropic Claude — used for AI rule evaluation, Chaos Lab, remediation prompts
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT — alternative LLM provider
OPENAI_API_KEY=sk-...

# Which LLM to use: anthropic | openai
LLM_PROVIDER=anthropic

# ─── Email (optional — for alert notifications) ───────────────────────────────

# Email provider: replit | smtp | console (console just prints to stdout)
EMAIL_PROVIDER=console

# SMTP settings (only needed if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Snapwire <you@gmail.com>

# ─── Slack Integration (optional) ────────────────────────────────────────────

# Slack Bot Token for Vibe-Audit weekly summaries and alert notifications
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#snapwire-alerts

# ─── Sentinel Proxy (optional — sidecar mode) ────────────────────────────────

# Port the Sentinel transparent proxy listens on
SENTINEL_PORT=8080

# Sentinel operating mode: observe | audit | enforce
SENTINEL_MODE=observe

# ─── Telemetry (optional — opt-in anonymous usage data) ──────────────────────

# Set to "true" to opt in to anonymous usage telemetry
SNAPWIRE_TELEMETRY=false

# ─── GitHub Fork Tracker (optional) ──────────────────────────────────────────

# GitHub Personal Access Token — increases API rate limit from 60 to 5000 req/hr
# Only needs read:public_repo scope. Leave blank to use unauthenticated (60/hr).
GITHUB_TOKEN=ghp_...
